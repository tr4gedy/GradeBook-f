<Window x:Class="GradeBook.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Журнал успеваемости" Height="900" Width="1300" FontSize="16"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="350"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Группа:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                    <ComboBox Width="180" ItemsSource="{Binding Groups}"
                              SelectedItem="{Binding SelectedGroup}" DisplayMemberPath="Name" 
                              VerticalAlignment="Center" Margin="0,0,5,0"/>

                    <TextBox Width="150"
                             Text="{Binding NewGroupName, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center" Margin="0,0,5,0"
                             ToolTip="Название новой группы"/>
                    <Button Content="➕ Добавить" Command="{Binding AddGroupCommand}" 
                            Padding="8,4" Margin="0,0,5,0" Background="#E0F2F1" BorderBrush="#B2DFDB"/>
                    <Button Content="❌ Удалить" Command="{Binding DeleteGroupCommand}" 
                            Padding="8,4" Margin="0,0,15,0" Background="#FFEBEE" BorderBrush="#FFCDD2"/>

                    <Border Width="1" Height="24" Background="#CCCCCC" Margin="10,0,20,0"/>

                    <TextBlock Text="Дисциплина:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                    <ComboBox Width="180" ItemsSource="{Binding Subjects}"
                              SelectedItem="{Binding SelectedSubject}" DisplayMemberPath="Title" 
                              VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1" 
                           Text="{Binding GroupAverage, StringFormat='Средний балл группы: {0:F2}'}" 
                           VerticalAlignment="Center" HorizontalAlignment="Right" 
                           FontWeight="Bold" FontSize="16" Foreground="DarkGreen" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,10">
            <TextBlock Text="Студент:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <TextBox Width="300"
                     Text="{Binding NewStudentFullName, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center" Margin="0,0,10,0"
                     ToolTip="ФИО нового студента"/>
            <Button Content="➕ Добавить студента..." Command="{Binding AddStudentCommand}" 
                    Padding="12,6" Margin="0,0,10,0" FontWeight="SemiBold"
                    Background="#E3F2FD" BorderBrush="#BBDEFB"/>
            <Button Content="❌ Удалить студента" Command="{Binding DeleteStudentCommand}" 
                    Padding="12,6" Margin="0,0,15,0" FontWeight="SemiBold"
                    Background="#FFEBEE" BorderBrush="#FFCDD2"/>

            <TextBlock Text="💡 ПКМ по студенту в таблице — управление его оценками и история" 
                       VerticalAlignment="Center" Foreground="Gray" FontStyle="Italic" FontSize="14"/>
        </StackPanel>

        <DataGrid Grid.Row="2" AutoGenerateColumns="False"
                  PreviewMouseRightButtonDown="StudentsGrid_PreviewMouseRightButtonDown"
                  ItemsSource="{Binding Students}"
                  SelectedItem="{Binding SelectedStudent}"
                  IsReadOnly="True" CanUserAddRows="False" 
                  RowHeight="38" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  BorderBrush="LightGray" BorderThickness="1" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО Студента" Binding="{Binding FullName}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0,0,0"/>
                            <Setter Property="FontSize" Value="15"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Средний балл" 
                                    Binding="{Binding Average, StringFormat=F2}" 
                                    Width="180">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="15"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>

            <DataGrid.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="➕ Добавить оценку..." Command="{Binding AddGradeCommand}"/>
                    <MenuItem Header="📝 Просмотр/Редактирование оценок..." Command="{Binding OpenGradesWindowCommand}"/>
                    <Separator/>
                    <MenuItem Header="❌ Удалить студента" Command="{Binding DeleteStudentCommand}" Foreground="Red"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <Border Grid.Row="3" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Margin="0,15,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="📊 Сравнительный рейтинг студентов по среднему баллу" 
                           FontWeight="SemiBold" Margin="10,8,0,0" Foreground="#555555"/>
                <lvc:CartesianChart Grid.Row="1" Series="{Binding RatingSeries}" XAxes="{Binding XAxes}" Margin="10"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="📄 Экспорт ведомости в PDF" Command="{Binding ExportPdfCommand}" 
                    Padding="15,8" FontWeight="SemiBold" 
                    Background="#2196F3" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>